{
  "name": "chakra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:studio": "npm --workspace packages/studio run build",
    "deploy:studio": "wrangler pages deploy packages/studio/dist --project-name chakra-studio --branch master",
    "deploy:worker": "npm --workspace packages/worker run deploy",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "lint:fix": "eslint 'packages/*/src/**/*.ts' --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "deepsec": "^2.1.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.106.0"
  }
}
